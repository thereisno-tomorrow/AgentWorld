{
  "name": "agentworld",
  "version": "0.1.0",
  "description": "Fallout Shelter-style cross-section UI for Claude Code vault sessions",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.svelte",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "start": "electron-vite preview",
    "dev": "SET ELECTRON_RUN_AS_NODE=&& electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thereisno-tomorrow/AgentWorld.git"
  },
  "author": "thereisno-tomorrow",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tsconfig/svelte": "^5.0.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-svelte": "^2.35.0",
    "prettier": "^3.1.0",
    "svelte": "^5.53.6",
    "svelte-check": "^3.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
